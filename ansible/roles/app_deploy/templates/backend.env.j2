# {{ ansible_managed }}
# Rendered by Ansible – do not edit on server.

APP_KEY={{ backend_app_key }}
HASH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3
AWS_ACCESS_KEY={{ aws_access_key }}
AWS_SECRET_ACCESS_KEY={{ aws_secret_access_key }}
S3_BUCKET_NAME={{ s3_bucket_name }}
AWS_REGION={{ aws_region | default('ap-south-1') }}

# Database
DATABASE_URL=postgresql+asyncpg://{{ pg_user }}:{{ pg_password }}@localhost:5432/{{ pg_db }}

# Mail
MAIL_USERNAME={{ mail_username | default('') }}
MAIL_PASSWORD={{ mail_password | default('') }}
MAIL_SERVER={{ mail_server | default('') }}
MAIL_PORT={{ mail_port | default('') }}
MAIL_FROM_ADDRESS={{ mail_from | default('') }}

# App
PRODUCTION=True
DOMAIN={{ domain }}
FRONTEND_URL=https://{{ domain }}
MAX_UPLOAD_SIZE=10
